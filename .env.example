# ============================================================
# Social Analytics — API Credentials Template
# คัดลอกไฟล์นี้เป็น .env แล้วใส่ค่าจริง
# ============================================================

# ── FACEBOOK ─────────────────────────────────────────────────
# วิธีหา: Meta Business Suite → Settings → Page Access Tokens
# หรือ: developers.facebook.com → Graph API Explorer
FB_PAGE_ID=your_page_id_here
FB_PAGE_ACCESS_TOKEN=your_long_lived_page_access_token_here

# ── INSTAGRAM ────────────────────────────────────────────────
# วิธีหา: IG Business Account ID จาก Graph API
# GET https://graph.facebook.com/me/accounts → ดู instagram_business_account.id
IG_ACCOUNT_ID=your_instagram_business_account_id_here

# ── TIKTOK ───────────────────────────────────────────────────
# วิธีหา: developers.tiktok.com → My Apps → App Detail → Access Token
TIKTOK_ACCESS_TOKEN=your_tiktok_access_token_here
TIKTOK_OPEN_ID=your_tiktok_open_id_here

# ── SETTINGS ─────────────────────────────────────────────────
# จำนวนวันที่ดึงข้อมูลย้อนหลัง (default: 30)
FETCH_DAYS=30
